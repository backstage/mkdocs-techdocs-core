{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Renovate configuration for mkdocs-techdocs-core. Validated by .github/workflows/validate-renovate.yml on every PR that touches this file.",

  "extends": [
    "config:recommended",
    ":disableDependencyDashboard",
    ":label(dependencies)",
    ":gitSignOff"
  ],

  "packageRules": [
    { "matchCategories": ["python"], "rangeStrategy": "widen" },
    { "matchPackageNames": ["mkdocs-material"], "allowedVersions": "<=9.15" }
  ]
}
